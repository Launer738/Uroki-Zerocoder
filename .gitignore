# ============================================
# .GITIGNORE - файлы, которые Git будет игнорировать
# ============================================
# Этот файл говорит Git, какие файлы НЕ нужно отслеживать
# ============================================

# ============================================
# ВИРТУАЛЬНОЕ ОКРУЖЕНИЕ
# ============================================
# Виртуальное окружение содержит установленные библиотеки
# Его НЕ нужно коммитить в репозиторий!
# Каждый разработчик создает свое окружение локально
# ============================================
venv/
env/
ENV/
.venv/

# ============================================
# КЭШ И СКОМПИЛИРОВАННЫЕ ФАЙЛЫ PYTHON
# ============================================
# Python создает эти файлы автоматически
# Их не нужно хранить в репозитории
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ============================================
# ФАЙЛЫ С ПЕРЕМЕННЫМИ ОКРУЖЕНИЯ
# ============================================
# Могут содержать секретные данные (пароли, ключи API)
# НИКОГДА не коммитьте такие файлы!
# ============================================
.env
.env.local
.env.*.local

# ============================================
# IDE И РЕДАКТОРЫ КОДА
# ============================================
# Настройки редакторов - у каждого свои
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# ЛОГИ И ВРЕМЕННЫЕ ФАЙЛЫ
# ============================================
*.log
*.tmp
*.temp

# ============================================
# ФАЙЛЫ ОПЕРАЦИОННОЙ СИСТЕМЫ
# ============================================
# Системные файлы Windows/Mac/Linux
# ============================================
Thumbs.db
.DS_Store
desktop.ini

# ============================================
# ДИСТРИБУТИВЫ И АРХИВЫ
# ============================================
*.zip
*.tar
*.tar.gz
*.rar

# ============================================
# PYGAME СПЕЦИФИЧНЫЕ ФАЙЛЫ (если есть)
# ============================================
# Если вы сохраняете скриншоты или другие файлы игры
# *.png
# *.jpg
# (раскомментируйте, если не хотите коммитить изображения)
